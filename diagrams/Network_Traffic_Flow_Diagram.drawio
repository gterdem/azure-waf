        <mxCell id="summary_title" parent="1" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" value="Traffic Flow Summary" vertex="1">
          <mxGeometry height="25" width="200" x="1300" y="750" as="geometry" />
        </mxCell>
        <mxCell id="summary_table" parent="1" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fontColor=#333333;spacing=6;" value="&lt;table style=&#39;border-collapse:collapse;width:100%;&#39;&gt;&lt;tr style=&#39;background:#1B3A5C;color:white;&#39;&gt;&lt;td style=&#39;padding:5px;&#39;&gt;&lt;b&gt;Step&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:5px;&#39;&gt;&lt;b&gt;From → To&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:5px;&#39;&gt;&lt;b&gt;What Happens&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#E8F5E9;&#39;&gt;&lt;td style=&#39;padding:4px;color:#107C10;&#39;&gt;&lt;b&gt;①&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;User → Internet&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Browser sends HTTP request (Port 80)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;color:#107C10;&#39;&gt;&lt;b&gt;②&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Internet → Public IP&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;DNS resolves, traffic hits Azure Public IP&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#E8F5E9;&#39;&gt;&lt;td style=&#39;padding:4px;color:#107C10;&#39;&gt;&lt;b&gt;③&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Public IP → App Gateway&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Enters VNet, reaches Application Gateway&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;color:#107C10;&#39;&gt;&lt;b&gt;④&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Inside App Gateway&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;WAF inspects: custom rules → managed rules → load balance&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#E8F5E9;&#39;&gt;&lt;td style=&#39;padding:4px;color:#107C10;&#39;&gt;&lt;b&gt;⑤&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;App Gateway → VM&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Clean traffic forwarded to backend (Port 3000)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;color:#0078D4;&#39;&gt;&lt;b&gt;⑥&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Inside VM&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Juice Shop processes request, generates response&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#FFEBEE;&#39;&gt;&lt;td style=&#39;padding:4px;color:#D13438;&#39;&gt;&lt;b&gt;⑦&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;VM → App Gateway&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;HTTP response sent back to gateway&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;color:#D13438;&#39;&gt;&lt;b&gt;⑧&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;App Gateway → Public IP&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Response exits VNet through gateway&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#FFEBEE;&#39;&gt;&lt;td style=&#39;padding:4px;color:#D13438;&#39;&gt;&lt;b&gt;⑨&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Public IP → Internet&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Response routed back through Internet&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;padding:4px;color:#D13438;&#39;&gt;&lt;b&gt;⑩&lt;/b&gt;&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Internet → User&lt;/td&gt;&lt;td style=&#39;padding:4px;&#39;&gt;Browser receives and renders the page&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="330" width="560" x="1290" y="780" as="geometry" />
        </mxCell>
