        <mxCell id="log_note_title" parent="1" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fontColor=#7B1FA2;" value="Parallel: Diagnostic Logging" vertex="1">
          <mxGeometry height="20" width="240" x="1300" y="568" as="geometry" />
        </mxCell>
        <mxCell id="log_note_detail" parent="1" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#555555;" value="Throughout steps ③–⑧, the Application&lt;br&gt;Gateway sends diagnostic logs to:&lt;br&gt;&lt;b&gt;• Azure Monitor → Log Analytics&lt;/b&gt;&lt;br&gt;&lt;b&gt;• WAF logs, Access logs, Perf logs&lt;/b&gt;&lt;br&gt;These are used by FireWatch AI and&lt;br&gt;KQL dashboards for monitoring." vertex="1">
          <mxGeometry height="85" width="240" x="1300" y="592" as="geometry" />
        </mxCell>
        <mxCell id="log_arrow" edge="1" parent="1" style="endArrow=block;html=1;strokeColor=#9C27B0;strokeWidth=1.5;endFill=1;dashed=1;dashPattern=6 3;" value="">
