        <mxCell id="log_note_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#CE93D8;strokeWidth=1.5;arcSize=8;dashed=1;dashPattern=6 3;" value="" vertex="1">
